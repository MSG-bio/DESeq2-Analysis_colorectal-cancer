library(DESeq2)
library(ggplot2)
library(pheatmap)
library(RColorBrewer)
library(ggrepel)
library(EnhancedVolcano)
library(GEOquery)
library(org.Hs.eg.db)
library(tidyverse)
library(dplyr)
dat <- read_tsv(file = 'GSE142279_raw_counts_GRCh38.p13_NCBI.tsv')
gse <- getGEO(GEO= "GSE142279", GSEMatrix = TRUE)
names(pData(gse[[1]]))
metadata <- pData(phenoData(gse[[1]]))
head(metadata)
metadata.mod <- metadata %>%
select(1,2,36) %>%
rename(tissue = 'tissue:ch1')
dat <- as.data.frame(dat)
rownames(dat) <- dat$GeneID
dat$GeneID <- NULL
dat[1:5, 1:5]
head(metadata.mod)
rownames(metadata.mod) <- metadata.mod$geo_accession
head(metadata.mod)
all(colnames(dat) == rownames(metadata.mod))
all(colnames(dat) %in% rownames(metadata.mod)
all(colnames(dat) %in% rownames(metadata.mod))
all(colnames(dat) %in% rownames(metadata.mod))
gn()
?DESeqDataSetFromMatrix
View(metadata.mod)
dds <- DESeqDataSetFromMatrix(countData = dat, colData = metadata.mod, design = ~ tissue)
dds
keep <- rowSums(counts(dds)) >= 10
dds <- dds[keep,]
dim(dds)
dim(dds)
dds$tissue <- relevel(dds$tissue, ref = "adjacent normal")
table(metadata.mod$title)
dds <- DESeq(dds)
res <- results(dds)
res
summary(res)
res.sig <- res[which(res$padj < 0.05 & abs(res$log2FoldChange) > 1), ]
nrow(res.sig)
table(res.sig$log2FoldChange > 0)
gc()
EnhancedVolcano(res,
lab     = rownames(res),
x       = 'log2FoldChange',
y       = 'padj',
pCutoff = 0.05,
FCcutoff = 1,
title   = 'Tumour vs Adjacent Normal',
subtitle = 'Colorectal Cancer — GSE142279')
library(org.Hs.eg.db)
gene_symbols <- mapIds(org.Hs.eg.db,
keys      = rownames(res),
column    = "SYMBOL",
keytype   = "ENTREZID",
multiVals = "first")
EnhancedVolcano(res,
lab      = gene_symbols,
x        = 'log2FoldChange',
y        = 'padj',
pCutoff  = 0.05,
FCcutoff = 1,
title    = 'Tumour vs Adjacent Normal',
subtitle = 'Colorectal Cancer — GSE142279')
?dev.off
png("Volcano_plot_GSE142279_final.png", width = 10, height = 8, units = "in", res = 300)
EnhancedVolcano(res,
lab      = gene_symbols,
x        = 'log2FoldChange',
y        = 'padj',
pCutoff  = 0.05,
FCcutoff = 1,
title    = 'Tumour vs Adjacent Normal',
subtitle = 'Colorectal Cancer — GSE142279')
dev.off()
top30 <- order(res$padj)[1:30]
mat <- counts(dds, normalized = TRUE)[top30, ]
mat <- log2(mat + 1)
rownames(mat) <- gene_symbols[rownames(mat)]
library(pheatmap)
annotation <- data.frame(
Tissue = metadata.mod$tissue,
row.names = rownames(metadata.mod)
)
pheatmap(mat,
annotation_col = annotation,
show_colnames  = FALSE,
fontsize_row   = 8,
main           = "Top 30 DE Genes — GSE142279")
png("Heatmap_GSE142279_final.png", width = 10, height = 12, units = "in", res = 300)
pheatmap(mat,
annotation_col = annotation,
show_colnames  = FALSE,
fontsize_row   = 8,
main           = "Top 30 DE Genes — GSE142279")
dev.off()
dev.off()
png("Heatmap_GSE142279_final.png", width = 10, height = 12, units = "in", res = 300)
pheatmap(mat,
annotation_col = annotation,
show_colnames  = FALSE,
fontsize_row   = 8,
main           = "Top 30 DE Genes — GSE142279")
dev.off()
